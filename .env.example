# Copie este arquivo para .env e preencha com seus dados reais
# NUNCA commite o arquivo .env no git

# Chave secreta para assinar licenças — gere uma senha forte aleatória
# Exemplo: python -c "import secrets; print(secrets.token_hex(32))"
TRIPABOT_SECRET_KEY=TROQUE_AQUI_POR_UMA_SENHA_FORTE_32_CHARS

# Senha de acesso ao painel admin (SÓ VOCÊ terá isso)
ADMIN_PASSWORD=TROQUE_AQUI_PELA_SUA_SENHA_ADMIN

# Porta do servidor (padrão 5000)
PORT=5000

# Modo debug (True para desenvolvimento, False para produção)
DEBUG=True
